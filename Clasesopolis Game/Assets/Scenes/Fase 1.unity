  m_Script: {fileID: 11500000, guid: 1d67102fc5db6124c84211621e94977a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  botonContinuar: {fileID: 2071371408}
  parlanteVoces: {fileID: 0}
  pasos:
  - nombrePaso: Bienvenda
    mensajeTexto: 
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 0}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 1800316452}
    desactivarAlEntrar: []
  - nombrePaso: Explicacion_1
    mensajeTexto: "En esta fase, aprender\xE1s a reconocer una clase dentro del mundo
      de la programaci\xF3n. \xA1Ser\xE1 tu primera misi\xF3n para empezar a dar
      forma a Clases\xF3polis!"
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 1112594127}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 2119607180}
    desactivarAlEntrar:
    - {fileID: 1800316452}
  - nombrePaso: JuegoSimple
    mensajeTexto: 
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 1112594127}
    esRetoInteractivos: 1
    objetoDelReto: {fileID: 543251188}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar: []
    desactivarAlEntrar:
    - {fileID: 2119607180}
  - nombrePaso: Explicacion_2
    mensajeTexto: "Una clase es un plano o molde que define c\xF3mo ser\xE1n los
      objetos. Especifica las caracter\xEDsticas y comportamientos que esos objetos
      tendr\xE1n cuando se creen."
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 374300640}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 409022795}
    desactivarAlEntrar:
    - {fileID: 543251188}
  - nombrePaso: Explicacion_3
    mensajeTexto: Por lo que una clase puede ser una casa,  edificio,  museo, o biblioteca.
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 2038211433}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 1467353010}
    desactivarAlEntrar:
    - {fileID: 409022795}
  - nombrePaso: Consejito
    mensajeTexto: "Te doy un consejito para que pod\xE1s identificar una clase."
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 1038610261}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 2070103598}
    desactivarAlEntrar:
    - {fileID: 1467353010}
  - nombrePaso: Preparado_para_reto
    mensajeTexto: "Ahora que ya sab\xE9s el concepto de Clase \xBFest\xE1s listo
      para empezar el reto?"
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 815482769}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 1499433433}
    desactivarAlEntrar:
    - {fileID: 2070103598}
  - nombrePaso: Informacion_reto
    mensajeTexto: "En el siguiente reto, se te presentar\xE1n diferentes elementos
      de la ciudad. Algunos de ellos son planos de edificios, y otros no. Tu misi\xF3n
      es identificar cu\xE1les representan clases y cu\xE1les no. Recuerda, una clase
      es un plano, no una construcci\xF3n real."
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 1935174767}
    esRetoInteractivos: 0
    objetoDelReto: {fileID: 0}
    esPasoFinal: 0
    escenaDestino: 
    numeroFase: 1
    activarAlEntrar:
    - {fileID: 1810977273}
    desactivarAlEntrar:
    - {fileID: 1499433433}
  - nombrePaso: RetoArrastraItem
    mensajeTexto: 
    audioPaso: {fileID: 0}
    panelPrincipal: {fileID: 752424388}
    textoUI: {fileID: 0}
    esRetoInteractivos: 1
