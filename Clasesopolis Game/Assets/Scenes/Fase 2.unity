  m_Script: {fileID: 11500000, guid: 4bdc3226398a323458d66f1afe97def6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  flujoPrincipal: {fileID: 0}
  textoFeedback: {fileID: 735403294}
  puntosXP: 30
  audioSource: {fileID: 0}
  sonidoCorrecto: {fileID: 0}
  sonidoError: {fileID: 0}
  botonMateriales: {fileID: 0}
  mensajeMateriales: "\xA1Casi! pero antes de tener materiales o trabajadores, necesitamos
    saber qu\xE9 construiremos. "
  materialesEsCorrecto: 0
  botonTrabajadores: {fileID: 0}
  mensajeTrabajadores: "Uff casi, pero pens\xE1 en aquello que te sirve para previsualizar
    como se ver\xE1 la ciudad."
  trabajadoresEsCorrecto: 0
  botonPlanos: {fileID: 0}
  mensajePlanos: "\xA1Le diste donde era! Antes de colocar el primer ladrillo, necesitamos
    un plano que indique c\xF3mo ser\xE1 cada construcci\xF3n.\L En programaci\xF3n,
    ese plano se llama Clase."
  planosEsCorrecto: 1
